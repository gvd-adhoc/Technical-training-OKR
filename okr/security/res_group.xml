<odoo>
    <record id="module_category_okr" model="ir.module.category">
        <field name="name">OKR</field>
        <field name="description">Manage OKR, objectives and key results</field>
    </record>

    <record id="privilege_okr" model="res.groups.privilege">
        <field name="name">OKR</field>
        <field name="category_id" ref="module_category_okr"/>
    </record>

    <record id="group_okr_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_okr"/>
    </record>

    <record id="group_okr_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_okr"/>
        <field name="implied_ids" eval="[(4, ref('okr.group_okr_user'))]"/>
    </record>
</odoo>
