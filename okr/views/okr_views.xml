<odoo>
    <record id="okr_action" model="ir.actions.act_window">
        <field name="name">OKR</field>
        <field name="res_model">okr</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="okr_list_view" model="ir.ui.view">
        <field name="name">okr.list</field>
        <field name="model">okr</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="level" />
                <field name="in_charge_id" />
                <field name="start_date" />
                <field name="end_date" />
            </list>
        </field>
    </record>

    <record id="okr_form_view" model="ir.ui.view">
        <field name="name">okr.form</field>
        <field name="model">okr</field>
        <field name="arch" type="xml">
            <form string="OKR">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                            name="action_view_child_okrs"
                            type="object"
                            icon="fa-sitemap"
                            invisible="not child_ids">
                            <field name="child_count" string="Child OKRs" widget="statinfo" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Title" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <group>
                                <field name="level" />
                                <field name="company_ids" widget="many2many_tags"
                                    options="{'no_create': True}"
                                    invisible="level != 'organization'" />
                                <field name="team_ids" widget="many2many_tags"
                                    options="{'no_create': True}" invisible="level != 'team'" />
                                <field name="employee_ids" widget="many2many_tags"
                                    options="{'no_create': True}" invisible="level != 'individual'" />
                                <field name="parent_id"
                                    domain="[('id', '!=', id), ('id', 'not in', child_ids)]" />
                                <field name="in_charge_id" />
                            </group>
                            <group>
                                <field name="start_date" />
                                <field name="end_date" />
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="cadence" />
                            </group>
                            <group>
                                <field name="year" invisible="parent_id" />
                            </group>
                        </group>
                    </group>
                    <notebook>
                        <page string="Objectives" invisible="not id">
                            <field name="objective_ids">
                                <list>
                                    <field name="description" />
                                    <field name="in_charge_id" />
                                    <field name="result" widget="percentage" />
                                    <field name="cadence" />
                                    <field name="start_date" />
                                    <field name="end_date" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
