<odoo>
    <record id="okr_action" model="ir.actions.act_window">
        <field name="name">OKR</field>
        <field name="res_model">okr</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="okr_list_view" model="ir.ui.view">
        <field name="name">okr.list</field>
        <field name="model">okr</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="level"/>
                <field name="in_charge_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="okr_form_view" model="ir.ui.view">
        <field name="name">okr.form</field>
        <field name="model">okr</field>
        <field name="arch" type="xml">
            <form string="OKR">
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="level"/>
                        <field name="in_charge_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <notebook>
                        <page string="Child OKRs">
                            <field name="child_ids">
                                <list>
                                    <field name="title"/>
                                    <field name="level"/>
                                    <field name="in_charge_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Objectives">
                            <field name="objective_ids">
                                <list>
                                    <field name="description"/>
                                    <field name="in_charge_id"/>
                                    <field name="result"/>
                                    <field name="cadence"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
