<odoo>
    <record id="okr_key_result_action" model="ir.actions.act_window">
        <field name="name">Key Results</field>
        <field name="res_model">okr.key_result</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="okr_key_result_list_view" model="ir.ui.view">
        <field name="name">okr.key.result.list</field>
        <field name="model">okr.key_result</field>
        <field name="arch" type="xml">
            <list>
                <field name="objective_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="in_charge_id"/>
                <field name="result" widget="percentage"/>
                <field name="target" widget="percentage"/>
                <field name="weight" widget="percentage"/>
            </list>
        </field>
    </record>

    <record id="okr_key_result_form_view" model="ir.ui.view">
        <field name="name">okr.key.result.form</field>
        <field name="model">okr.key_result</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="objective_id"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="in_charge_id"/>
                        <field name="result" widget="percentage"/>
                        <field name="target" widget="percentage"/>
                        <field name="weight" widget="percentage"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
