<odoo>
    <record id="okr_key_result_action" model="ir.actions.act_window">
        <field name="name">Key Results</field>
        <field name="res_model">okr.key_result</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="okr_key_result_list_view" model="ir.ui.view">
        <field name="name">okr.key.result.list</field>
        <field name="model">okr.key_result</field>
        <field name="arch" type="xml">
            <list>
                <field name="objective_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="in_charge_id"/>
                <field name="result" widget="percentage"/>
                <field name="target" widget="percentage"/>
                <field name="weight" widget="percentage"/>
            </list>
        </field>
    </record>

    <record id="okr_key_result_form_view" model="ir.ui.view">
        <field name="name">okr.key.result.form</field>
        <field name="model">okr.key_result</field>
        <field name="arch" type="xml">
            <form>
                <field name="state" invisible="True"/>
                <header>
                    <button name="set_active" type="object" string="Activate" invisible="state!='draft' and state!='cancelled'" class="btn-primary"/>
                    <button name="set_cancelled" type="object" string="Cancel" invisible="state!='draft' and state!='active'" class="btn-danger"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Draft" bg_color="text-bg-primary" invisible="state!='draft'"/>
                    <widget name="web_ribbon" title="Active" bg_color="text-bg-success" invisible="state!='active'"/>
                    <widget name="web_ribbon" title="Done" bg_color="text-bg-info" invisible="state!='done'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger" invisible="state!='cancelled'"/>
                    <group>
                        <group>
                            <field name="objective_id"/>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="in_charge_id"/>
                        </group>
                        <group>
                            <group>
                                <field name="result" widget="percentage"/>
                                <field name="target" widget="percentage"/>
                                <field name="weight" widget="percentage"/>
                            </group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
