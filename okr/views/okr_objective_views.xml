<odoo>
    <record id="okr_objective_action" model="ir.actions.act_window">
        <field name="name">Objectives</field>
        <field name="res_model">okr.objective</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="okr_objective_list_view" model="ir.ui.view">
        <field name="name">okr.objective.list</field>
        <field name="model">okr.objective</field>
        <field name="arch" type="xml">
            <list>
                <field name="okr_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="in_charge_id"/>
                <field name="result"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="okr_objective_form_view" model="ir.ui.view">
        <field name="name">okr.objective.form</field>
        <field name="model">okr.objective</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="okr_id"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="type"/>
                        <field name="in_charge_id"/>
                        <field name="cadence"/>
                        <field name="result" widget="percentage"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <notebook>
                        <page string="Key Results" invisible="not id">
                            <field name="key_result_ids">
                                <list>
                                    <field name="description"/>
                                    <field name="in_charge_id"/>
                                    <field name="result" widget="percentage"/>
                                    <field name="target" widget="percentage"/>
                                    <field name="weight" widget="percentage"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="okr_objective_search_view" model="ir.ui.view">
        <field name="name">okr.objective.search</field>
        <field name="model">okr.objective</field>
        <field name="arch" type="xml">
            <search string="Objectives">
                <field name="name"/>
                <field name="okr_id"/>
                <field name="cadence"/>
                <field name="in_charge_id"/>
                <field name="type"/>
                <filter name="my_objective" string="My Objectives" domain="[('in_charge_id', '=', uid)]"/>
                <filter name="group_by_in_charge" string="In Charge" context="{'group_by': 'in_charge_id'}"/>
                <filter name="group_by_type" string="Type" context="{'group_by': 'type'}"/>
            </search>
        </field>
    </record>
</odoo>
